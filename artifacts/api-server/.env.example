# ============================================================
# NEXUS API Server — Environment Variables
# Copy this file to .env and fill in real values for production.
# In Firebase Functions, set these via:
#   firebase functions:secrets:set VAR_NAME
# ============================================================

# ── Server ────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
SESSION_SECRET=replace-with-a-long-random-string-32chars+

# CORS: comma-separated list of allowed frontend origins
# Example: https://nexus-app.vercel.app,https://nexus.yourdomain.com
CORS_ORIGIN=https://your-vercel-app.vercel.app

# ── Firebase ──────────────────────────────────────────────
# From: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-firebase-project.appspot.com
# Optional — only if using Firebase Realtime Database
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# ── Google Workspace ──────────────────────────────────────
# From: Google Cloud Console → IAM → Service Accounts → Keys → Add Key (JSON)
# Paste the ENTIRE contents of the downloaded JSON file as a single-line string
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\\n...\\n-----END RSA PRIVATE KEY-----\\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"...","token_uri":"..."}

# Spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/<SHEETS_ID>/edit
GOOGLE_SHEETS_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Drive folder ID from the URL: https://drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_FOLDER_ID=1A2B3C4D5E6F7G8H9I0J

# ── AI Providers ──────────────────────────────────────────
# From: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# From: https://platform.openai.com/api-keys (optional — GPT-4o fallback)
OPENAI_API_KEY=sk-...

# ── Telegram Bots ─────────────────────────────────────────
# From: @BotFather on Telegram → /newbot → copy token
TELEGRAM_BOT_TOKEN_MAIN=123456:ABCdef...
TELEGRAM_BOT_TOKEN_SECONDARY=789012:GHIjkl...
TELEGRAM_BOT_TOKEN_BACKUP=345678:MNOpqr...

# Optional: a secret string to validate incoming webhook payloads
# Set this when registering the webhook: ?secret_token=YOUR_VALUE
TELEGRAM_WEBHOOK_SECRET=replace-with-random-string
