# ============================================================
# NEXUS Frontend (Vite / React) — Environment Variables
# All VITE_* vars are embedded at build time — do NOT put secrets here.
# Set these in Vercel → Project → Settings → Environment Variables.
# ============================================================

# Full URL to your Firebase Functions API backend (no trailing slash).
# Example: https://us-central1-your-project.cloudfunctions.net/api
# Or your custom domain: https://api.nexus.yourdomain.com
VITE_API_BASE_URL=https://us-central1-your-firebase-project.cloudfunctions.net/api

# App name shown in the browser tab (optional)
VITE_APP_NAME=NEXUS
